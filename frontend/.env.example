# Aegis Frontend Environment Configuration
# Copy this file to .env.local and customize as needed

# =============================================================================
# API Configuration
# =============================================================================

# Public API URL (accessible from browser)
# This should be the external URL where the backend API is accessible
NEXT_PUBLIC_API_URL=http://localhost:8000

# Internal API URL (server-side only, within Docker network)
# Used for server components and API routes
INTERNAL_API_URL=http://backend:8000

# =============================================================================
# Application
# =============================================================================

# Environment: development, production, test
NODE_ENV=development
