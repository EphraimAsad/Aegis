# Aegis .gitignore

# =============================================================================
# Project-specific
# =============================================================================
Masterprompt.txt
.claude
Currentprogress.txt

# =============================================================================
# Environment files
# =============================================================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# Keep example files
!.env.example
!**/.env.example

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
# Note: Don't ignore frontend/lib/ - only Python lib directories
lib/
!frontend/lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv/

# Pytest
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Ruff
.ruff_cache/

# =============================================================================
# Node.js / Next.js
# =============================================================================
node_modules/
.next/
out/
.nuxt/
dist/

# npm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Turborepo
.turbo/

# Vercel
.vercel/

# =============================================================================
# IDE and Editors
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-workspace
*.sublime-project

# =============================================================================
# OS Files
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# =============================================================================
# Docker
# =============================================================================
# Ignore docker-compose override files that might contain secrets
docker-compose.override.yml

# =============================================================================
# Database
# =============================================================================
*.db
*.sqlite
*.sqlite3

# =============================================================================
# Logs
# =============================================================================
logs/
*.log

# =============================================================================
# Temporary files
# =============================================================================
tmp/
temp/
.tmp/
*.tmp
*.bak
*.backup

# =============================================================================
# Coverage reports
# =============================================================================
coverage/
*.lcov

# =============================================================================
# Build artifacts
# =============================================================================
*.pyc
*.pyo
*.pyd
.build/

# =============================================================================
# Secrets and credentials
# =============================================================================
*.pem
*.key
*.crt
secrets/
credentials/
