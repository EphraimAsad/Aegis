# Aegis Backend Environment Configuration
# Copy this file to .env and customize as needed

# =============================================================================
# Database
# =============================================================================
# For Docker: use postgres as host
# For local dev: use localhost
DATABASE_URL=postgresql+asyncpg://aegis:aegis_dev_password@localhost:5432/aegis

# Sync URL for Alembic migrations
DATABASE_URL_SYNC=postgresql://aegis:aegis_dev_password@localhost:5432/aegis

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Ollama (Local LLM)
# =============================================================================
OLLAMA_BASE_URL=http://localhost:11434

# =============================================================================
# Provider Configuration
# =============================================================================
DEFAULT_PROVIDER=ollama
DEFAULT_MODEL=llama2

# API Keys (uncomment as needed)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...

# =============================================================================
# Security
# =============================================================================
SECRET_KEY=change-this-in-production-use-a-long-random-string

# CORS Origins (JSON array format)
CORS_ORIGINS=["http://localhost:3000"]

# =============================================================================
# Environment
# =============================================================================
ENVIRONMENT=development
DEBUG=true
