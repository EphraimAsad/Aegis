# Aegis Environment Configuration
# Copy this file to .env and customize as needed

# =============================================================================
# Database Configuration
# =============================================================================
POSTGRES_USER=aegis
POSTGRES_PASSWORD=aegis_dev_password
POSTGRES_DB=aegis
POSTGRES_PORT=5432

# Full database URL (used by backend)
DATABASE_URL=postgresql+asyncpg://aegis:aegis_dev_password@postgres:5432/aegis

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

# =============================================================================
# Ollama Configuration (Local LLM)
# =============================================================================
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_PORT=11434

# =============================================================================
# Provider Configuration
# =============================================================================
# Default provider: ollama, openai, anthropic, gemini
DEFAULT_PROVIDER=ollama

# Default model (provider-specific)
# For Ollama: llama2, mistral, codellama, etc.
# For OpenAI: gpt-4, gpt-3.5-turbo, etc.
# For Anthropic: claude-3-opus, claude-3-sonnet, etc.
DEFAULT_MODEL=llama2

# API Keys (uncomment and set as needed)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=AIza...

# To switch providers, set DEFAULT_PROVIDER to one of: ollama, openai, anthropic, google
# and set the corresponding API key above

# =============================================================================
# Service Ports
# =============================================================================
BACKEND_PORT=8000
FRONTEND_PORT=3000

# =============================================================================
# Security
# =============================================================================
# IMPORTANT: Change this in production!
SECRET_KEY=change-this-in-production-use-a-long-random-string

# =============================================================================
# Environment
# =============================================================================
ENVIRONMENT=development
DEBUG=true
